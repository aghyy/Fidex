SEED_USER_EMAIL=demo@example.com

# Secret shared with Vercel Cron Jobs. Set this on the Vercel project (Settings
# → Environment Variables) to require a bearer token for cron invocations.
# Vercel will automatically send `Authorization: Bearer $CRON_SECRET` to any
# scheduled handler when this variable exists.
CRON_SECRET=replace-me-with-a-long-random-value
